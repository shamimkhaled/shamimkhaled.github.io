# EmailJS - Contact form (get keys from https://www.emailjs.com/)
REACT_APP_EMAILJS_SERVICE_ID=your_service_id
REACT_APP_EMAILJS_TEMPLATE_ID=your_template_id
REACT_APP_EMAILJS_PUBLIC_KEY=your_public_key

# Admin dashboard (used when Supabase is NOT configured)
REACT_APP_ADMIN_USERNAME=admin
REACT_APP_ADMIN_PASSWORD=your_secure_password

# Supabase (optional - when set, portfolio data is stored in Supabase)
# Get these from https://supabase.com/dashboard/project/_/settings/api
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_anon_key

# Optional: Pre-fill admin email on login form (Supabase auth)
REACT_APP_SUPABASE_ADMIN_EMAIL=

# Dev.to username for blog posts
REACT_APP_DEVTO_USERNAME=shamimkhaled
